---
// src/pages/[...slug].astro
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import LinkFixer from '../components/LinkFixer.astro';
import LinkDebugInfo from '../components/LinkDebugInfo.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import Footer from '../components/Footer.astro'
import path from 'node:path';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((entry) => {
    const slug = entry.id.replace(/\/index$/, '').replace(/\.md$/, '');
    return {
      params: { slug: slug === 'index' ? undefined : slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const pageTitle = entry.data.title || path.basename(entry.id, '.md');
const currentAstroPath = Astro.url.pathname;

// 外部リンク抽出ロジック
const rawContent = entry.body || '';
const mdLinkRegex = /\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g;
const detectedExternalLinks: { title: string; url: string }[] = [];
let match;
while ((match = mdLinkRegex.exec(rawContent)) !== null) {
  const [_, title, url] = match;
  if (!detectedExternalLinks.some(l => l.url === url.trim())) {
    detectedExternalLinks.push({ title: title.trim(), url: url.trim() });
  }
}
---

<BaseLayout title={pageTitle} externalLinks={detectedExternalLinks}>
  <LinkDebugInfo 
    entry={entry} 
    externalLinks={detectedExternalLinks} 
    currentPath={currentAstroPath} 
  />

  <div class="markdown-content prose max-w-none">
    <RelatedLinks entry={entry} />    
    <Content />
    <RelatedLinks entry={entry} />    
  </div>

  <LinkFixer mode="page" />
  <Footer />
</BaseLayout>