---
// src/components/LinkFixer.astro
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  mode: 'page' | 'anchor';
}

const { mode } = Astro.props;

// 全ドキュメントの取得と型指定
const allDocs: CollectionEntry<'docs'>[] = await getCollection('docs');

// 検索用辞書の作成
// 型推論を効かせるため、mapで明示的にオブジェクト構造を定義
const urlRegistry = allDocs.map((doc) => {
  const filename = doc.id.split('/').pop()?.replace(/\.md$/, '') || '';
  // スラッグからURLを生成（indexはルートへ、それ以外はパス形式へ）
  const url = doc.id.replace(/\/index$/, '').replace(/\.md$/, '') === 'index' 
    ? '/' 
    : `/${doc.id.replace(/\/index$/, '')}`;
    
  return {
    filename,
    url,
    id: doc.id
  };
});
---

<div
  id="astro-link-meta"
  data-registry={JSON.stringify(urlRegistry)}
  data-mode={mode}
  style="display: none;"
>
</div>

<script>
  // スクリプト内の型定義
  interface RegistryItem {
    filename: string;
    url: string;
    id: string;
  }

  function fixLinks() {
    const metaEl = document.getElementById('astro-link-meta');
    if (!metaEl) return;

    const registry: RegistryItem[] = JSON.parse(metaEl.getAttribute('data-registry') || '[]');
    const mode = metaEl.getAttribute('data-mode');

    const links = document.querySelectorAll<HTMLAnchorElement>('.markdown-content a');

    links.forEach((link) => {
      const href = link.getAttribute('href');
      if (!href) return;

      // 1. 外部リンク処理 (http/https で始まるもの)
      if (href.startsWith('http')) {
        link.setAttribute('target', '_blank');
        link.setAttribute('rel', 'noopener noreferrer');
        return;
      }

      // アンカーリンク自体はスキップ
      if (href.startsWith('#')) return;

      // 2. 内部リンクの補正
      const decoded = decodeURIComponent(href);
      const match = registry.find((item) => decoded.includes(item.filename));

      if (match) {
        if (mode === 'anchor') {
          link.setAttribute('href', '#' + match.id);
        } else {
          link.setAttribute('href', encodeURI(match.url));
        }
      }
    });
  }

  // 実行
  document.addEventListener("astro:page-load", fixLinks)

</script>