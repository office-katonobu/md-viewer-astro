---
// src/components/ExternalLinks.astro

interface Props {
  links: { title: string; url: string }[];
}

const { links:externalLinks } = Astro.props;
---

{externalLinks.length > 0 && (
    <div>
    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">🔗 本文内の外部リンク</p>
    <ul class="pl-1 list-none space-y-1">
        {externalLinks.map((link: { title: string; url: string }) => (
        <li>
            <a 
            href={link.url} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="block py-1.5 px-2 rounded-lg text-sm text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors no-underline items-center justify-between group"
            >
            <span class="truncate pr-2">🔗 {link.title}</span>
            <span class="text-xs text-slate-300 group-hover:text-slate-400 transition-colors shrink-0">↗</span>
            </a>
        </li>
        ))}
    </ul>
    </div>
)}
