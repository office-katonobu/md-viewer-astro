---
import { ClientRouter } from "astro:transitions"
const config = {
  site: {
    // ブラウザタブや検索結果に表示されるタイトル
    title: "ISO-27001 ドキュメントサンプル | katonobu",

    // SEO・SNSカードに使われる短い説明文
    description: "セキュリティコンサルティングを行う個人事業主がIS-27001を取ろうとしたときのサンプルドキュメントです。これをベースに拡充して使うことを想定しています。",

    // 公開する本番URL（GitHub Pages / CloudFront / Vercel など）
    url: "https://isms.office-katonobu.com",

    // 著者名（著作権表記やmetaタグに使用）
    author: "katonobu",

    // HTML の lang 属性（日本語サイトなら "ja"）
    locale: "ja",
  },
}

interface Props {
  title: string
}

const { title: pageTitle } = Astro.props

const siteName = config.site.title
const isHome = Astro.url.pathname === "/"
const fullTitle = isHome
  ? siteName
  : pageTitle
    ? `${pageTitle} — ${siteName}`
    : siteName
const description = config.site.description
const socialImage = new URL("/og-image.png", config.site.url)
const canonicalURL = new URL(Astro.url.pathname, config.site.url)
---

{/* Global Metadata */}
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<meta name="author" content={config.site.author} />

{/* Canonical URL */}
<link rel="canonical" href={canonicalURL} />

{/* Primary Meta Tags */}
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<link rel="sitemap" href="/sitemap-index.xml" />

{/* Open Graph / Facebook */}
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImage} />

{/* Twitter */}
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImage} />

{/* Favicons */}
<link
  rel="icon"
  type="image/png"
  href="/favicons/favicon-96x96.png"
  sizes="96x96"
/>
<link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
<link rel="shortcut icon" href="/favicons/favicon.ico" />
<link
  rel="apple-touch-icon"
  sizes="180x180"
  href="/favicons/apple-touch-icon.png"
/>

{/* App */}
<meta name="apple-mobile-web-app-title" content={siteName} />
<link rel="manifest" href="/favicons/site.webmanifest" />

{/* Optional */}
<meta name="robots" content="noindex, nofollow" />


{/* View Transition API */}
<ClientRouter />
