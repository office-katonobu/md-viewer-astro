---
// =========================================================================
// 🔲 src/layouts/BaseLayout.astro
// =========================================================================

import '../styles/global.css';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { buildSidebarTree } from '../utils/sidebar';
import SidebarTree from '../components/SidebarTree.astro'; // ★コンポーネントをインポート

interface SidebarTreeType {
  folders: Record<string, SidebarTreeType>;
  files: { url: string; title: string; isIndex: boolean }[];
}

const { title, externalLinks = [] } = Astro.props;
const allDocs: CollectionEntry<'docs'>[] = await getCollection('docs');

// ★ロジック抽出: ユーティリティ関数を使用
const tree = buildSidebarTree(allDocs);
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="bg-slate-50 text-slate-800">
    <div class="flex min-h-screen max-w-7xl mx-auto">
      
      <aside class="w-64 bg-white border-r border-slate-200 p-6 sticky top-0 h-screen overflow-y-auto flex flex-col justify-between">
        <div class="space-y-6">
          
          <div>
            <a href="/" class="text-xl font-bold text-slate-900 no-underline">🏠 ドキュメントTOP</a>
          </div>
          
          <nav class="space-y-6">
            <div>
              <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">📁 ドキュメントツリー</p>
              
              <SidebarTree tree={tree} />
              
            </div>

            {externalLinks.length > 0 && (
              <div>
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">🔗 本文内の外部リンク</p>
                <ul class="pl-1 list-none space-y-1">
                  {externalLinks.map((link: { title: string; url: string }) => (
                    <li>
                      <a 
                        href={link.url} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="block py-1.5 px-2 rounded-lg text-sm text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors no-underline flex items-center justify-between group"
                      >
                        <span class="truncate pr-2">🔗 {link.title}</span>
                        <span class="text-xs text-slate-300 group-hover:text-slate-400 transition-colors flex-shrink-0">↗</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </nav>
        </div>
      </aside>

      <main class="flex-1 bg-white p-12 overflow-x-hidden">
        <div class="max-w-3xl mx-auto">
          <article class="prose prose-slate max-w-none">
            <slot /> </article>
        </div>
      </main>

    </div>

    <script>
      function initSidebarDynamicBehavior() {
        const currentPath = window.location.pathname.replace(/^\/|\/$/g, '');
        if (!currentPath) return;

        const pathParts = currentPath.split('/');

        pathParts.forEach((part) => {
          const decodedPart = decodeURIComponent(part);
          const folderElement = document.querySelector(
            `details[data-folder-raw="${decodedPart}"], details[data-folder-encoded="${part}"]`
          );
          
          if (folderElement) {
            folderElement.setAttribute('open', 'true');
          }
        });

        const links = document.querySelectorAll('.sidebar-file');
        links.forEach((link) => {
          const rawUrl = link.getAttribute('data-raw-url');
          if (rawUrl) {
            const targetPath = rawUrl.replace(/^\/|\/$/g, '');
            if (targetPath === currentPath || encodeURI(targetPath) === currentPath) {
              link.classList.remove('text-slate-600', 'hover:bg-slate-100', 'hover:text-slate-900');
              link.classList.add('bg-blue-50', 'text-blue-600', 'font-semibold');
            }
          }
        });
      }

      document.addEventListener('DOMContentLoaded', initSidebarDynamicBehavior);
    </script>
  </body>
</html>